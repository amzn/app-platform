        <mxCell id="whyBox" value="&lt;b&gt;Warum diese Trennung?&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;1. Kleinere Abhaengigkeitsgraphen&lt;br&gt;2. Weniger API Leakage&lt;br&gt;3. Einfachere Fakes in Tests&lt;br&gt;4. Bessere parallele Build-Schritte&lt;br&gt;5. Plattformdetails bleiben austauschbar&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;fontColor=#0F172A;fontSize=12;spacing=10;shadow=1;" vertex="1" parent="1">

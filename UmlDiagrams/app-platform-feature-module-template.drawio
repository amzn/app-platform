        <mxCell id="checklist" value="&lt;b&gt;Feature checklist&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;1. Put interfaces and Models in :public&lt;br&gt;2. Put production code in :impl&lt;br&gt;3. Add fakes to :testing when reused&lt;br&gt;4. Add UI robots when tests repeat user actions&lt;br&gt;5. Let :app assemble concrete impl modules&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;fontColor=#0F172A;fontSize=12;spacing=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="985" width="690" height="75" as="geometry" />
        </mxCell>
        <mxCell id="antiPattern" value="&lt;b&gt;Avoid&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Do not let another reusable feature depend directly on this feature's :impl module. That creates hidden coupling and leaks implementation details.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#F87171;fontColor=#7F1D1D;fontSize=12;spacing=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="985" width="670" height="75" as="geometry" />
        </mxCell>

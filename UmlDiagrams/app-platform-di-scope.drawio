        <mxCell id="note" value="&lt;b&gt;Warum pro Plattform?&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Der finale Graph lebt in plattformspezifischen Source Sets. Dadurch koennen Android, iOS, Desktop und Wasm eigene Werte bereitstellen, waehrend gemeinsamer Code nur APIs injiziert bekommt.&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#FEF9C3;strokeColor=#CA8A04;fontColor=#0F172A;fontSize=12;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="925" width="470" height="90" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="&lt;b&gt;DI-Fokus&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Metro ist der empfohlene Standard. kotlin-inject bleibt als Alternative verfuegbar. Beide pruefen den Objektgraphen zur Build-Zeit.&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#F3E8FF;strokeColor=#9333EA;fontColor=#0F172A;fontSize=12;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="925" width="430" height="90" as="geometry" />
        </mxCell>
        <mxCell id="note3" value="&lt;b&gt;Scope-Fokus&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Der Scope ist mehr als ein DI-Container: Er ist die Lebenszyklusgrenze, an der Services, Graphen und Coroutines haengen.&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#0F172A;fontSize=12;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1040" y="925" width="480" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

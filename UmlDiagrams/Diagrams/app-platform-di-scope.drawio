        <mxCell id="note3" parent="1" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#0F172A;fontSize=12;spacing=10;" value="&lt;b&gt;Scope-Fokus&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Der Scope ist mehr als ein DI-Container: Er ist die Lebenszyklusgrenze, an der Services, Graphen und Coroutines haengen.&lt;/font&gt;" vertex="1">

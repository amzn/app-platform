        <mxCell id="note2" parent="1" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#F3E8FF;strokeColor=#9333EA;fontColor=#0F172A;fontSize=12;spacing=10;" value="&lt;b&gt;DI-Fokus&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Metro ist der empfohlene Standard. kotlin-inject bleibt als Alternative verfuegbar. Beide pruefen den Objektgraphen zur Build-Zeit.&lt;/font&gt;" vertex="1">

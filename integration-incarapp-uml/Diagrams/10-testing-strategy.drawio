        <mxCell id="e6" value="coverage matrix" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#64748B;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#64748B;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="matrix" target="ci"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="code" value="&lt;b&gt;Presenter test sketch&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size: 12px;&quot;&gt;FakeVehicleInfoProvider(&lt;br&gt;  VehicleInfoResult.Available(&lt;br&gt;    VehicleInfo(&quot;Mercedes-Benz&quot;, &quot;EQS&quot;, &quot;...&quot;, true)&lt;br&gt;  )&lt;br&gt;)&lt;br&gt;&lt;br&gt;presenter.onEvent(InCarEvent.Refresh)&lt;br&gt;assertThat(model.vehicleState).isContent()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="540" y="965" width="720" height="135" as="geometry" /></mxCell>

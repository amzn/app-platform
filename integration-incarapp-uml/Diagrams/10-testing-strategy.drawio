        <mxCell id="title" value="&lt;b&gt;10 - Testing Strategy&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Testpyramide und Surface-Matrix fuer inCarApp-Platform&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontColor=#0F172A;fontSize=14;fontSize=34;fontColor=#102A43;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="25" width="1680" height="85" as="geometry" /></mxCell>
        <mxCell id="unit" value="&lt;b&gt;Shared Unit Tests&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Fast tests for domain, use cases, presenter mapping.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;FakeVehicleInfoProvider + capability fixtures&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="120" y="180" width="420" height="135" as="geometry" /></mxCell>
        <mxCell id="presenter" value="&lt;b&gt;Presenter Tests&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Events -&gt; provider result -&gt; InCarModel.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Loading, Content, Unsupported, PermissionRequired, Error&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="690" y="180" width="420" height="135" as="geometry" /></mxCell>
        <mxCell id="provider" value="&lt;b&gt;Provider Tests&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Automotive provider with mocked CarPropertyManager.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Permission and connection scenarios&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1260" y="180" width="420" height="135" as="geometry" /></mxCell>
        <mxCell id="rendererShared" value="&lt;b&gt;Shared Renderer Tests&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Render common composables with sample models.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;MB widgets when CMP-ready&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#E11D48;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="120" y="430" width="420" height="135" as="geometry" /></mxCell>
        <mxCell id="visual" value="&lt;b&gt;Visual / Screenshot Tests&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Automotive head-unit sizes, languages, RTL, styles.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Existing Roborazzi + MBTestKit idea remains valuable&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="690" y="430" width="420" height="135" as="geometry" /></mxCell>
        <mxCell id="integration" value="&lt;b&gt;Integration Tests&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Surface app + DI + renderer + fake provider.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Automotive, Phone, iOS host tests&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1260" y="430" width="420" height="135" as="geometry" /></mxCell>
        <mxCell id="matrix" value="&lt;b&gt;Surface Test Matrix&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Automotive: real/fake car provider&lt;br&gt;Phone: unsupported/remote states&lt;br&gt;iOS: unsupported/remote states&lt;br&gt;All: model/event behavior&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="260" y="715" width="520" height="180" as="geometry" /></mxCell>

  <diagram id="03-module-dependencies" name="03-module-dependencies">
    <mxGraphModel dx="1800" dy="1200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;03 - Module Dependencies&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Konkrete inCarApp-Modulstruktur mit erlaubten und verbotenen Abhaengigkeiten&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontColor=#0F172A;fontSize=14;fontSize=34;fontColor=#102A43;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="25" width="1680" height="85" as="geometry" /></mxCell>
        <mxCell id="rule" value="&lt;b&gt;Core rule&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Only final app modules may assemble concrete implementation modules. Reusable modules depend on public contracts.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;shape=note;size=18;" vertex="1" parent="1"><mxGeometry x="260" y="130" width="1280" height="80" as="geometry" /></mxCell>
        <mxCell id="public" value="&lt;b&gt;inCarApp:public&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Stable contracts.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;VehicleInfo, VehicleInfoProvider, InCarPresenter, InCarModel, InCarEvent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="130" y="300" width="310" height="130" as="geometry" /></mxCell>
        <mxCell id="impl" value="&lt;b&gt;inCarApp:impl&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Shared implementation.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;PresenterImpl, use cases, model mapping, policy orchestration&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="560" y="300" width="310" height="130" as="geometry" /></mxCell>
        <mxCell id="implAuto" value="&lt;b&gt;impl-android-automotive&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Real vehicle data.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;android.car.Car, CarPropertyManager, VehiclePropertyIds&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="990" y="250" width="310" height="120" as="geometry" /></mxCell>
        <mxCell id="implPhone" value="&lt;b&gt;impl-android-phone&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Phone fallback provider.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Remote, companion or NotSupported result&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="990" y="410" width="310" height="120" as="geometry" /></mxCell>
        <mxCell id="implIos" value="&lt;b&gt;impl-ios&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;iOS fallback provider.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Remote, demo or NotSupported result&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="990" y="570" width="310" height="120" as="geometry" /></mxCell>

        <mxCell id="rendererPhone" value="&lt;b&gt;renderer-android-phone&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Compose phone renderer.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Phone layout, shared CMP composables&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="560" y="680" width="310" height="120" as="geometry" /></mxCell>
        <mxCell id="rendererIos" value="&lt;b&gt;renderer-ios&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Compose Multiplatform iOS renderer.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;iOS host adaptation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="560" y="840" width="310" height="120" as="geometry" /></mxCell>
        <mxCell id="testing" value="&lt;b&gt;inCarApp:testing&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Fakes and fixtures.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;FakeVehicleInfoProvider, presenter fixtures, model samples&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="130" y="610" width="310" height="120" as="geometry" /></mxCell>
        <mxCell id="robots" value="&lt;b&gt;inCarApp:impl-robots&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Surface test robots.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;AutomotiveRobot, PhoneRobot, IosRobot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="130" y="780" width="310" height="120" as="geometry" /></mxCell>
        <mxCell id="appAuto" value="&lt;b&gt;app-automotive&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Final Automotive app.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;May depend on impl + renderer + provider impl&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1390" y="250" width="300" height="115" as="geometry" /></mxCell>
        <mxCell id="appPhone" value="&lt;b&gt;app-android-phone&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Final Phone app.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;May depend on impl + phone renderer + phone provider&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1390" y="450" width="300" height="115" as="geometry" /></mxCell>
        <mxCell id="appIos" value="&lt;b&gt;app-ios&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Final iOS app.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;May depend on impl + iOS renderer + iOS provider&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1390" y="650" width="300" height="115" as="geometry" /></mxCell>
        <mxCell id="forbid" value="&lt;b&gt;Forbidden shortcut&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;renderer or impl module must not import another concrete provider impl directly.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Use public contracts and app assembly instead.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1040" y="850" width="460" height="115" as="geometry" /></mxCell>

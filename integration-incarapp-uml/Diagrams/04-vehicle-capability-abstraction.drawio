  <diagram id="04-vehicle-capability-abstraction" name="04-vehicle-capability-abstraction">
    <mxGraphModel dx="1800" dy="1200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;04 - Vehicle Capability Abstraction&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Wie Fahrzeughardware gekapselt wird, ohne shared Business-Logik zu verlieren&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontColor=#0F172A;fontSize=14;fontSize=34;fontColor=#102A43;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="25" width="1680" height="85" as="geometry" /></mxCell>
        <mxCell id="presenter" value="&lt;b&gt;Shared Presenter&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Asks for capabilities, not platform classes.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;No android.car imports, no Context, no iOS APIs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="80" y="250" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="providerApi" value="&lt;b&gt;VehicleInfoProvider&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Public capability contract.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;suspend fun getVehicleInfo(): VehicleInfoResult&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="520" y="250" width="360" height="150" as="geometry" /></mxCell>
        <mxCell id="result" value="&lt;b&gt;VehicleInfoResult&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Explicit platform outcome.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Available, NotSupported, PermissionMissing, TemporarilyUnavailable, Error&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="520" y="480" width="360" height="170" as="geometry" /></mxCell>
        <mxCell id="autoImpl" value="&lt;b&gt;AndroidAutomotiveVehicleInfoProvider&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Real hardware implementation.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;android.car.Car + CarPropertyManager + VehiclePropertyIds&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1010" y="180" width="360" height="130" as="geometry" /></mxCell>
        <mxCell id="phoneImpl" value="&lt;b&gt;AndroidPhoneVehicleInfoProvider&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Phone implementation.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Remote data, companion data or NotSupported&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1010" y="360" width="360" height="130" as="geometry" /></mxCell>
        <mxCell id="iosImpl" value="&lt;b&gt;IosVehicleInfoProvider&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;iOS implementation.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Remote data, demo data or NotSupported&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1010" y="540" width="360" height="130" as="geometry" /></mxCell>
        <mxCell id="uiModel" value="&lt;b&gt;InCarModel&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Shared UI state derived from capability result.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Loading, Content, Unsupported, PermissionRequired, Error&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="80" y="520" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="policy" value="&lt;b&gt;DrivingStatePolicy&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Future safety and availability layer.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Available, ParkedOnly, DisabledWhileDriving&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1010" y="760" width="360" height="130" as="geometry" /></mxCell>
        <mxCell id="matrix" value="&lt;b&gt;Capability matrix&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Automotive: Available&lt;br&gt;Phone: Remote / NotSupported&lt;br&gt;iOS: Remote / NotSupported&lt;br&gt;Driving mode: later policy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1420" y="300" width="300" height="260" as="geometry" /></mxCell>
        <mxCell id="code" value="&lt;b&gt;Public API code sketch&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size: 12px;&quot;&gt;interface VehicleInfoProvider {&lt;br&gt;  suspend fun getVehicleInfo(): VehicleInfoResult&lt;br&gt;}&lt;br&gt;&lt;br&gt;sealed interface VehicleInfoResult {&lt;br&gt;  data class Available(val info: VehicleInfo) : VehicleInfoResult&lt;br&gt;  data object NotSupported : VehicleInfoResult&lt;br&gt;  data object PermissionMissing : VehicleInfoResult&lt;br&gt;  data class Error(val message: String) : VehicleInfoResult&lt;br&gt;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="80" y="770" width="780" height="245" as="geometry" /></mxCell>
        <mxCell id="e1" value="requests data" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#DB2777;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#DB2777;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="presenter" target="providerApi"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e2" value="returns explicit state" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D97706;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#D97706;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="providerApi" target="result"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e3" value="mapped to model" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#7C3AED;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#7C3AED;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="result" target="uiModel"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="impl0" value="implements" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563EB;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#2563EB;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="autoImpl" target="providerApi"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="impl1" value="implements" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563EB;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#2563EB;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="phoneImpl" target="providerApi"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="impl2" value="implements" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563EB;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#2563EB;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="iosImpl" target="providerApi"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="p1" value="filters availability" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#DC2626;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#DC2626;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="policy" target="uiModel"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="m1" value="capability row" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#16A34A;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#16A34A;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="autoImpl" target="matrix"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="m2" value="capability row" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#16A34A;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#16A34A;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="phoneImpl" target="matrix"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="m3" value="capability row" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#16A34A;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#16A34A;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="iosImpl" target="matrix"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="note" value="&lt;b&gt;Design decision&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Hardware access is not shared. Hardware capability semantics are shared.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;shape=note;size=18;" vertex="1" parent="1"><mxGeometry x="930" y="950" width="720" height="80" as="geometry" /></mxCell>

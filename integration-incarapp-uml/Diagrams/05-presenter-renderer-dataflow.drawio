        <mxCell id="e2" value="loads capability" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#DB2777;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#DB2777;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="presenter" target="provider"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e3" value="VehicleInfoResult" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563EB;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#2563EB;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="provider" target="presenter"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e4" value="emits" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#7C3AED;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#7C3AED;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="presenter" target="model"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e5" value="model type" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4F46E5;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#4F46E5;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="model" target="factory"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e6" value="Automotive surface" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#EA580C;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#EA580C;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="factory" target="autoR"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e7" value="Phone surface" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0284C7;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#0284C7;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="factory" target="phoneR"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e8" value="iOS surface" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4F46E5;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#4F46E5;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="factory" target="iosR"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="u0" value="renders" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#16A34A;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#16A34A;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="autoR" target="ui"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>

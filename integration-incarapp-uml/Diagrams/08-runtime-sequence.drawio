<mxfile host="app.diagrams.net" modified="2026-06-22T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="08-runtime-sequence" name="08-runtime-sequence">
    <mxGraphModel dx="1800" dy="1200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;08 - Runtime Sequence&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Startablauf fuer Automotive, Android Phone und iOS in der Zielplattform&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontColor=#0F172A;fontSize=14;fontSize=34;fontColor=#102A43;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="25" width="1680" height="85" as="geometry" /></mxCell>
        <mxCell id="s1" value="&lt;b&gt;1. Surface app starts&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Automotive MainActivity, Phone Activity or iOS host starts the platform runtime.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="80" y="200" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="s2" value="&lt;b&gt;2. RootScope created&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;The app creates a lifetime boundary for graph, coroutines and cleanup.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="500" y="200" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="s3" value="&lt;b&gt;3. AppGraph assembled&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Hilt today or KMP DI later wires provider, presenter and renderer factory.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="920" y="200" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="s4" value="&lt;b&gt;4. Provider selected&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Automotive real hardware, Phone fallback/remote, iOS fallback/remote.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1340" y="200" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="s5" value="&lt;b&gt;5. Presenter emits model&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Shared presenter maps capability result to InCarModel.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1340" y="550" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="s6" value="&lt;b&gt;6. Renderer selected&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;RendererFactory chooses Automotive, Phone or iOS renderer.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="920" y="550" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="s7" value="&lt;b&gt;7. UI rendered&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;MB widgets / Compose Multiplatform render the model.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="500" y="550" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="s8" value="&lt;b&gt;8. Event returns&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;User action calls model.onEvent(event); presenter emits new model.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="80" y="550" width="330" height="180" as="geometry" /></mxCell>
        <mxCell id="e12" value="start" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563EB;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#2563EB;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e23" value="lifetime" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#059669;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#059669;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e34" value="binds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#7C3AED;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#7C3AED;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e45" value="result" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0F766E;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#0F766E;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1505" y="470" /></Array></mxGeometry></mxCell>
        <mxCell id="e56" value="model" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#DB2777;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#DB2777;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="s5" target="s6"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e67" value="renderer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4F46E5;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#4F46E5;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="s6" target="s7"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e78" value="visible UI" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#EA580C;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#EA580C;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="s7" target="s8"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="loop" value="event loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#BE185D;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#BE185D;labelBackgroundColor=#FFFFFF;dashed=1;" edge="1" parent="1" source="s8" target="s5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="245" y="900" /><mxPoint x="1505" y="900" /></Array></mxGeometry></mxCell>
        <mxCell id="surfaceMap" value="&lt;b&gt;Surface examples&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Automotive: permission + real car info&lt;br&gt;Phone: remote or unsupported&lt;br&gt;iOS: remote or unsupported&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="240" y="950" width="510" height="100" as="geometry" /></mxCell>
        <mxCell id="failureMap" value="&lt;b&gt;Failure states&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;PermissionMissing, TemporarilyUnavailable, NotSupported, Error are model states, not random crashes.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1040" y="950" width="510" height="100" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

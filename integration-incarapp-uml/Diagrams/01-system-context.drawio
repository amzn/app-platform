<mxfile host="app.diagrams.net" modified="2026-06-22T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="01-system-context" name="01-system-context">
    <mxGraphModel dx="1800" dy="1200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;01 - inCarApp System Context&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Wer interagiert mit der Plattform, den Apps, Vehicle APIs und MB Widgets?&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontColor=#0F172A;fontSize=14;fontSize=34;fontColor=#102A43;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="25" width="1680" height="85" as="geometry" /></mxCell>
        <mxCell id="platform" value="&lt;b&gt;InCar App Platform&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Shared KMP architecture for Android Automotive, Android Phone and iOS.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Presenter, Models, Capability APIs, Renderer contracts, testing support&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="640" y="420" width="520" height="210" as="geometry" /></mxCell>
        <mxCell id="autoApp" value="&lt;b&gt;Automotive App&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Runs on Android Automotive head unit.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;MBApplication, MBActivity, Automotive permissions, real vehicle data&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="90" y="220" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="phoneApp" value="&lt;b&gt;Android Phone App&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Mobile surface for phone usage.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;May use remote, companion or unsupported vehicle states&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="90" y="470" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="iosApp" value="&lt;b&gt;iOS App&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Compose Multiplatform iOS surface.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Same models and events, iOS host lifecycle&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="90" y="720" width="330" height="150" as="geometry" /></mxCell>
        <mxCell id="vehicle" value="&lt;b&gt;Vehicle / Head Unit&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Android Automotive OS, IVI environment and vehicle services.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;android.car.Car, CarPropertyManager, VehiclePropertyIds&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1340" y="180" width="360" height="175" as="geometry" /></mxCell>
        <mxCell id="backend" value="&lt;b&gt;Backend / Remote Services&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Optional data source for phone and iOS.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Account, connected services, demo or companion data&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1340" y="455" width="360" height="160" as="geometry" /></mxCell>
        <mxCell id="mbwidgets" value="&lt;b&gt;MB Widgets&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Mercedes-Benz design components.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Automotive today, future Compose Multiplatform widgets&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#E11D48;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1340" y="700" width="360" height="160" as="geometry" /></mxCell>
        <mxCell id="teams" value="&lt;b&gt;Feature Teams&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Build features against public contracts.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Use templates, renderer contracts and test fixtures&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="650" y="160" width="250" height="135" as="geometry" /></mxCell>
        <mxCell id="platformTeam" value="&lt;b&gt;Platform Team&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Owns architecture and tooling.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Gradle plugin, module checks, starter, CI, documentation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="930" y="160" width="270" height="135" as="geometry" /></mxCell>
        <mxCell id="e1" value="uses shared contracts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563EB;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#2563EB;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="autoApp" target="platform"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e2" value="uses shared contracts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0284C7;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#0284C7;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="phoneApp" target="platform"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e3" value="uses shared contracts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4F46E5;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#4F46E5;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="iosApp" target="platform"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e4" value="Automotive provider calls" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#EA580C;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#EA580C;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="platform" target="vehicle"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e5" value="optional provider calls" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#059669;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#059669;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="platform" target="backend"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e6" value="renderer consumes widgets" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E11D48;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#E11D48;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="platform" target="mbwidgets"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e7" value="feature APIs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#64748B;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#64748B;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="teams" target="platform"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e8" value="evolves platform" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#64748B;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#64748B;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="platformTeam" target="platform"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="note" value="&lt;b&gt;Context rule&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;The platform should not hide every platform difference. It should make differences explicit through capabilities and renderers.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;shape=note;size=18;" vertex="1" parent="1"><mxGeometry x="560" y="900" width="680" height="90" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>

  <diagram id="11-roadmap" name="11-roadmap">
    <mxGraphModel dx="1800" dy="1200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;11 - Implementation Roadmap&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;MVP bis skalierte interne Plattform fuer Automotive, Android Phone und iOS&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontColor=#0F172A;fontSize=14;fontSize=34;fontColor=#102A43;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="25" width="1680" height="85" as="geometry" /></mxCell>
        <mxCell id="p0" value="&lt;b&gt;Phase 0&lt;br&gt;Baseline&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Document current inCarApp, align Gradle/Kotlin/AGP, keep tests as baseline.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="80" y="250" width="260" height="185" as="geometry" /></mxCell>
        <mxCell id="p1" value="&lt;b&gt;Phase 1&lt;br&gt;Public Contracts&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;VehicleInfoProvider, VehicleInfoResult, InCarModel, InCarEvent, fakes.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="390" y="250" width="260" height="185" as="geometry" /></mxCell>
        <mxCell id="p2" value="&lt;b&gt;Phase 2&lt;br&gt;Shared Presenter&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Move ViewModel logic into PresenterImpl and test with fake providers.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="700" y="250" width="260" height="185" as="geometry" /></mxCell>
        <mxCell id="p3" value="&lt;b&gt;Phase 3&lt;br&gt;Automotive Slice&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Real Android Automotive provider and MB widget renderer in target modules.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1010" y="250" width="260" height="185" as="geometry" /></mxCell>
        <mxCell id="p4" value="&lt;b&gt;Phase 4&lt;br&gt;Phone + iOS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Fallback/remote providers and Compose Multiplatform renderers.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1320" y="250" width="260" height="185" as="geometry" /></mxCell>
        <mxCell id="p5" value="&lt;b&gt;Phase 5&lt;br&gt;Platform Tooling&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Gradle plugin, module checks, templates, CI matrix, docs, governance.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="700" y="650" width="260" height="185" as="geometry" /></mxCell>
        <mxCell id="e01" value="start" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#64748B;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#64748B;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p0" target="p1"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e12" value="contracts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563EB;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#2563EB;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e23" value="MVP" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#DB2777;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#DB2777;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e34" value="expand surfaces" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#EA580C;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#EA580C;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e45" value="scale" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4F46E5;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#4F46E5;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1450" y="560" /><mxPoint x="830" y="560" /></Array></mxGeometry></mxCell>
        <mxCell id="decision1" value="&lt;b&gt;Decision gates&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;DI strategy: Hilt adapter first, KMP DI later&lt;br&gt;MB Widgets CMP API shape&lt;br&gt;Phone/iOS vehicle data strategy&lt;br&gt;Automotive safety policy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="150" y="700" width="420" height="190" as="geometry" /></mxCell>
        <mxCell id="success" value="&lt;b&gt;Success criteria&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Feature teams use templates&lt;br&gt;Shared presenter tests pass&lt;br&gt;Surface renderers consume same models&lt;br&gt;Vehicle hardware is isolated&lt;br&gt;CI catches module violations&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1180" y="700" width="420" height="190" as="geometry" /></mxCell>
        <mxCell id="code" value="&lt;b&gt;MVP module set&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size: 12px;&quot;&gt;MVP target modules:&lt;br&gt;inCarApp:public&lt;br&gt;inCarApp:impl&lt;br&gt;inCarApp:impl-android-automotive&lt;br&gt;inCarApp:renderer-automotive&lt;br&gt;inCarApp:testing&lt;br&gt;inCarApp:app-automotive&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="595" y="910" width="610" height="150" as="geometry" /></mxCell>

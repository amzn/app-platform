<mxfile host="app.diagrams.net" modified="2026-06-22T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="06-surface-renderer-strategy" name="06-surface-renderer-strategy">
    <mxGraphModel dx="1800" dy="1200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;06 - Surface Renderer Strategy&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Moeglichst viel UI teilen, ohne Automotive-, Phone- und iOS-Unterschiede zu verstecken&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;fontColor=#0F172A;fontSize=14;fontSize=34;fontColor=#102A43;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="25" width="1680" height="85" as="geometry" /></mxCell>
        <mxCell id="model" value="&lt;b&gt;Shared InCarModel&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Single source of UI truth.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Vehicle state, actions, capability states, text keys&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="690" y="150" width="420" height="125" as="geometry" /></mxCell>
        <mxCell id="foundation" value="&lt;b&gt;Shared UI Foundation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Common Compose Multiplatform building blocks.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;VehicleInfoCard, LoadingState, ErrorState, UnsupportedState&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#E11D48;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="620" y="370" width="560" height="145" as="geometry" /></mxCell>
        <mxCell id="mb" value="&lt;b&gt;MB Widgets&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Mercedes-Benz UI components.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Today Automotive-focused, future Multiplatform&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1220" y="370" width="360" height="145" as="geometry" /></mxCell>
        <mxCell id="auto" value="&lt;b&gt;Automotive Renderer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Head unit optimized.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;MBAppLayoutStatic, larger touch areas, future driving policy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="110" y="650" width="390" height="150" as="geometry" /></mxCell>
        <mxCell id="phone" value="&lt;b&gt;Android Phone Renderer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Phone optimized.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Compact navigation, portrait/landscape, phone permissions&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="705" y="650" width="390" height="150" as="geometry" /></mxCell>
        <mxCell id="ios" value="&lt;b&gt;iOS Renderer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Compose Multiplatform iOS.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;iOS host lifecycle, same shared composables&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1300" y="650" width="390" height="150" as="geometry" /></mxCell>
        <mxCell id="autoApp" value="&lt;b&gt;app-automotive&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Hosts Automotive renderer.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="110" y="910" width="390" height="90" as="geometry" /></mxCell>
        <mxCell id="phoneApp" value="&lt;b&gt;app-android-phone&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Hosts phone renderer.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="705" y="910" width="390" height="90" as="geometry" /></mxCell>
        <mxCell id="iosApp" value="&lt;b&gt;app-ios&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Hosts iOS renderer.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4F46E5;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1300" y="910" width="390" height="90" as="geometry" /></mxCell>
        <mxCell id="code" value="&lt;b&gt;Shared UI code sketch&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size: 12px;&quot;&gt;@Composable&lt;br&gt;fun VehicleInfoCard(model: VehicleInfoModel, onEvent: (InCarEvent) -&amp;gt; Unit) {&lt;br&gt;  MBText(model.title)&lt;br&gt;  MBButton(..., onClick = { onEvent(InCarEvent.Refresh) })&lt;br&gt;}&lt;br&gt;&lt;br&gt;// Surface renderers decide layout, not business behavior.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="120" y="335" width="430" height="200" as="geometry" /></mxCell>
        <mxCell id="e1" value="drives common UI" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#7C3AED;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#7C3AED;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="model" target="foundation"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e2" value="uses widgets" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E11D48;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#E11D48;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="foundation" target="mb"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e3" value="reused by" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#EA580C;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#EA580C;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="foundation" target="auto"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e4" value="reused by" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0284C7;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#0284C7;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="foundation" target="phone"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="e5" value="reused by" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4F46E5;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#4F46E5;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="foundation" target="ios"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="a" value="hosted in" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#EA580C;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#EA580C;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="auto" target="autoApp"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="p" value="hosted in" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0284C7;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#0284C7;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="phone" target="phoneApp"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="i" value="hosted in" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4F46E5;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontStyle=1;fontColor=#4F46E5;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="ios" target="iosApp"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
        <mxCell id="note" value="&lt;b&gt;Sharing boundary&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Share state rendering and widgets where possible. Keep layout density, safety behavior and host lifecycle surface-specific.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;fontSize=15;spacing=16;shadow=1;arcSize=8;shape=note;size=18;" vertex="1" parent="1"><mxGeometry x="570" y="1060" width="700" height="80" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
